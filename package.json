{
  "name": "gitvana",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "dev:server": "bun run --watch server.ts",
    "serve": "bun run server.ts",
    "postinstall": "sed -i.bak 's/var delta, size, fp, p, r, i, k, lastStartX, lastStartY, result;/var delta, size, fp, p, r, i, k, lastStartX, lastStartY, result, ed;/' node_modules/diff3/onp.js && rm -f node_modules/diff3/onp.js.bak"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/howler": "^2.2.12",
    "@unocss/svelte-scoped": "^66.6.7",
    "fake-indexeddb": "^6.2.5",
    "typescript": "~5.9.3",
    "unocss": "^66.6.7",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "buffer": "^6.0.3",
    "diff3": "^0.0.4",
    "elkjs": "^0.11.1",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "isomorphic-git": "^1.37.4",
    "svelte": "^5.55.0"
  }
}
